# Copy to .env for local overrides, or set these directly in your host's
# dashboard (e.g. Render's Environment tab). Never commit a real .env file.

# postgresql://... in production (Render provides this automatically when
# you attach a Postgres instance). Defaults to a local SQLite file if unset.
DATABASE_URL=

# Comma-separated list of frontend origins allowed to send credentialed
# requests here, e.g. https://finadvisor.onrender.com
FRONTEND_ORIGIN=http://localhost:3000

# Required in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# "development" (default) or "production". Controls whether JWT_SECRET is
# enforced and whether the session cookie is issued as SameSite=None;
# Secure (needed once frontend/backend are on different domains).
ENVIRONMENT=development
